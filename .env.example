# ============================================================
# Salve - Environment Variables
# ============================================================
# Copy to .env.local and fill in values.
# Variables prefixed VITE_ are exposed to the client bundle.
# All others are server-only (Vercel env vars / api/ functions).
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...your-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key
# SUPABASE_URL is an optional server-side fallback for VITE_SUPABASE_URL
# SUPABASE_URL=https://your-project.supabase.co

# ── AI Providers ─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...

# ── Stripe Billing ───────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PREMIUM_PRICE_ID=price_...monthly
STRIPE_ANNUAL_PRICE_ID=price_...annual
VITE_BILLING_ENABLED=false

# ── Oura Ring ────────────────────────────────────────────────
OURA_CLIENT_ID=
OURA_CLIENT_SECRET=

# ── Dexcom CGM ───────────────────────────────────────────────
DEXCOM_CLIENT_ID=
DEXCOM_CLIENT_SECRET=
# Set to "true" for sandbox-api.dexcom.com during development
DEXCOM_USE_SANDBOX=true
VITE_DEXCOM_ENABLED=false

# ── Withings ─────────────────────────────────────────────────
WITHINGS_CLIENT_ID=
WITHINGS_CLIENT_SECRET=
VITE_WITHINGS_ENABLED=false

# ── Fitbit (legacy Web API, sunsets Sept 2026) ───────────────
FITBIT_CLIENT_ID=
FITBIT_CLIENT_SECRET=
VITE_FITBIT_ENABLED=false

# ── Whoop (requires app review before credentials) ───────────
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
VITE_WHOOP_ENABLED=false

# ── Terra Wearable Aggregator ────────────────────────────────
TERRA_DEV_ID=
TERRA_API_KEY=
TERRA_SIGNING_SECRET=
TERRA_AUTH_SUCCESS_URL=https://your-domain.com/?terra=success
TERRA_AUTH_FAILURE_URL=https://your-domain.com/?terra=failure
VITE_TERRA_ENABLED=false

# ── Push Notifications (Web Push / VAPID) ────────────────────
VAPID_EMAIL=mailto:your-email@example.com
VAPID_PRIVATE_KEY=
VITE_VAPID_PUBLIC_KEY=

# ── Cron Jobs ────────────────────────────────────────────────
# Shared secret to authenticate Vercel cron invocations
CRON_SECRET=

# ── Sentry Error Reporting ───────────────────────────────────
VITE_SENTRY_DSN=https://...@....ingest.us.sentry.io/...
# Optional: enable Sentry in dev mode for testing the scrub pipeline
# VITE_SENTRY_DSN_DEV=
# Optional: correlate errors to commits (set automatically by Vercel)
# VITE_SENTRY_RELEASE=
# Build-time only: used by @sentry/vite-plugin for source maps
# SENTRY_AUTH_TOKEN=

# ── CORS ─────────────────────────────────────────────────────
# Custom allowed origin for API endpoints (e.g., your production domain)
# ALLOWED_ORIGIN=https://your-domain.com

# ── Vercel (auto-set by platform) ────────────────────────────
# VERCEL_URL is auto-populated by Vercel at build + runtime
# VERCEL_URL=

# ── Beta ─────────────────────────────────────────────────────
# Set to "true" to require invite codes on the sign-in screen
VITE_BETA_INVITE_REQUIRED=false
